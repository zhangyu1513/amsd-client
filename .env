# 基础环境配置
# 所有环境共享的配置

# 应用基础配置
VITE_APP_NAME=AMSD Client
VITE_APP_VERSION=1.0.0

# API 配置
VITE_API_TIMEOUT=30000
VITE_API_MAX_RETRIES=3

# 功能开关
VITE_FEATURE_AUTH=true
VITE_FEATURE_MOCK=false

# 日志配置
VITE_LOG_LEVEL=info
VITE_LOG_CONSOLE_ENABLED=true

# 安全配置
VITE_CORS_ENABLED=false
VITE_CSRF_ENABLED=false